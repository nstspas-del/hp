# ─── HP Тюнинг — переменные окружения ────────────────────────────────────────
# Скопируйте этот файл в .env.local и заполните реальными значениями
# cp .env.example .env.local

# ─── Яндекс.Метрика ───────────────────────────────────────────────────────────
# Получить: https://metrika.yandex.ru → Добавить счётчик
NEXT_PUBLIC_YM_COUNTER_ID=108614238

# ─── Яндекс.Вебмастер (верификация) ──────────────────────────────────────────
# Получить: https://webmaster.yandex.ru → Добавить сайт → HTML-мета тег
NEXT_PUBLIC_YANDEX_VERIFICATION=612ea2d0128620d8

# ─── URL сайта ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://hptuning.ru

# ─── AutoDealer (НЕ МЕНЯТЬ — ключ зафиксирован в src/lib/autodealer.ts) ───────
# AUTODEALER_KEY=107eb24c04be7f0ef6676d5aa84dc46132fb7e6bdb6ac10b8adcf74e6e8633dd

# ─── Для локальной разработки можно переопределить URL ────────────────────────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
